藏语文本清洗工具
作者：Dawa-8
"""

import re

def clean_tibetan_text(text):
    text = re.sub(r'\s+', ' ', text)
    text = re.sub(r'[^\u0F00-\u0FFF]', '', text)
    text = text.strip()
    return text

if __name__ == "__main__":
    test_text = " བཀྲ་ཤིས་བདེ་ལེགས།  !!! 123 "
    cleaned = clean_tibetan_text(test_text)
    print("清洗前:", test_text)
    print("清洗后:", cleaned)
